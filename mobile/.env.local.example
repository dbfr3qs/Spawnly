# Local dev config for the Spawnly mobile app (Tier A: make bootstrap + SSE).
# Copy to .env.local and adjust the host. Metro inlines EXPO_PUBLIC_* into the
# build, and src/config.ts / app.config.js read them.
#
#   - Android emulator reaches the host loopback at 10.0.2.2.
#   - A physical iPhone must use the host's LAN IP (e.g. 192.168.1.50) and you
#     must port-forward with `--address 0.0.0.0` (see plans/mobile-ciba/testing-plan.md).
#
# Start from these (Android emulator example):

EXPO_PUBLIC_GATEWAY_URL=http://10.0.2.2:8091
EXPO_PUBLIC_ISSUER=http://10.0.2.2:8090
EXPO_PUBLIC_CLIENT_ID=mobile

# Explicit OIDC endpoints (REQUIRED locally — discovery would hand back the
# unreachable in-cluster issuer host). Point at the dashboard-proxied /connect.
EXPO_PUBLIC_AUTH_ENDPOINT=http://10.0.2.2:8090/connect/authorize
EXPO_PUBLIC_TOKEN_ENDPOINT=http://10.0.2.2:8090/connect/token

# DEV ONLY: allow plain-HTTP (cleartext) to the local/LAN port-forwards. NEVER
# set this in a production build.
EXPO_PUBLIC_ALLOW_CLEARTEXT=true
