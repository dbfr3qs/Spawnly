# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored.

# region        = "us-east-1"
# cluster_name  = "spawnly"

# Grant your kubectl identity cluster-admin at apply time so you never have to
# run create-access-entry / associate-access-policy by hand. For an AWS SSO role,
# use the underlying IAM role ARN (with the aws-reserved/sso path), e.g.:
#
#   aws iam list-roles \
#     --query "Roles[?contains(RoleName,'AWSReservedSSO_AdministratorAccess')].Arn" --output text
#
# cluster_admin_principal_arns = [
#   "arn:aws:iam::<ACCOUNT_ID>:role/aws-reserved/sso.amazonaws.com/AWSReservedSSO_AdministratorAccess_<id>",
#   "arn:aws:iam::<ACCOUNT_ID>:user/spawnly-terraform",
# ]
