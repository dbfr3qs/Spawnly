# Terraform state holds real account IDs/ARNs and can hold secrets — never commit.
*.tfstate
*.tfstate.*
# Provider plugins / module cache (large, machine-specific).
.terraform/
# Local var/override files.
*.tfvars
override.tf
override.tf.json
crash.log
crash.*.log
# Keep .terraform.lock.hcl committed (provider version pinning).
