{
  "agentType": "hotel-search",
  "version": "1.0.0",
  "status": "active",
  "requiresTenant": false,
  "oauthScopes": ["openid", "hotels:read"],
  "meta": {
    "displayName": "Hotel Search",
    "description": "A least-privilege specialist that searches hotels via the travel-tools MCP server's search_hotels tool, using a token scoped to only hotels:read."
  },
  "runtimeSpec": {
    "image": "agent-travel-specialist:latest",
    "lifecycle": "long-lived",
    "resources": { "cpuLimits": "500m", "memoryLimits": "256Mi" },
    "envDefaults": {
      "MCP_URL": "http://travel-tools/mcp",
      "MCP_TOOL": "search_hotels",
      "MCP_SCOPE": "hotels:read"
    }
  },
  "authzTemplate": { "spiceDbRelations": [] }
}
