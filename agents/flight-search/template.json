{
  "agentType": "flight-search",
  "version": "1.0.0",
  "status": "active",
  "requiresTenant": false,
  "oauthScopes": ["openid", "flights:read"],
  "meta": {
    "displayName": "Flight Search",
    "description": "A least-privilege specialist that searches flights via the travel-tools MCP server's search_flights tool, using a token scoped to only flights:read."
  },
  "runtimeSpec": {
    "image": "agent-travel-specialist:latest",
    "lifecycle": "long-lived",
    "resources": { "cpuLimits": "500m", "memoryLimits": "256Mi" },
    "envDefaults": {
      "MCP_URL": "http://travel-tools/mcp",
      "MCP_TOOL": "search_flights",
      "MCP_SCOPE": "flights:read"
    }
  },
  "authzTemplate": { "spiceDbRelations": [] }
}
