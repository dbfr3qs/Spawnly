{
  "agentType": "global-worker",
  "version": "1.0.0",
  "status": "active",
  "requiresTenant": false,
  "meta": {"displayName": "Global Worker", "description": "Tenant-less worker that calls a tenant-agnostic sample API and exits"},
  "runtimeSpec": {
    "image": "agent-go-worker:latest",
    "lifecycle": "short-lived",
    "resources": {"cpuLimits": "500m", "memoryLimits": "256Mi"},
    "envDefaults": {
      "SAMPLE_API_URL": "http://sample-api-global",
      "SCOPE": "sample-api-a:write",
      "TASK": "hello from a tenant-less agent",
      "LOG_LEVEL": "info"
    }
  },
  "authzTemplate": {
    "spiceDbRelations": []
  },
  "delegation": {"allowedChildTypes": [], "grantableScopes": [], "maxDepth": 0}
}
