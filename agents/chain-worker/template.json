{
  "agentType": "chain-worker",
  "version": "1.0.0",
  "status": "active",
  "requiresTenant": true,
  "meta": {
    "displayName": "Chain Worker",
    "description": "A long-lived worker that spawns one child of its own type (up to maxDepth) and calls the sample API on a loop. Used to demonstrate cascading, real-time permission revocation across an agent chain."
  },
  "runtimeSpec": {
    "image": "agent-chain-worker:latest",
    "lifecycle": "long-lived",
    "resources": {"cpuLimits": "500m", "memoryLimits": "256Mi"},
    "envDefaults": {
      "SCOPE": "sample-api-a:read",
      "WORK_INTERVAL_MS": "3000"
    }
  },
  "authzTemplate": {
    "spiceDbRelations": [
      {"resource": "tenant:{{tenant_id}}", "relation": "agent", "subject": "agent:{{agent_id}}"}
    ]
  },
  "delegation": {"allowedChildTypes": ["chain-worker"], "grantableScopes": [], "maxDepth": 4}
}
