# Copy to .env (gitignored) and fill in your key. Sourced by scripts/bootstrap.sh.
#
#   cp .env.example .env
#   # edit .env, then:
#   make bootstrap

# Provider: "anthropic" (default) or "openai".
AI_PROVIDER=anthropic

# API key for the selected provider. Used by both parent and child agents.
# For anthropic you may instead set ANTHROPIC_API_KEY; for openai, OPENAI_API_KEY.
AI_API_KEY=

# Optional — override the default model for the provider.
# anthropic default: anthropic/claude-sonnet-4-6
# openai default:    openai/gpt-4o
# AI_MODEL=anthropic/claude-sonnet-4-6

# The travel-tools MCP server's upstream keys (Duffel/LiteAPI) are NOT here — they
# belong to that one service, so they live in mcp/travel-tools/.env (see its
# .env.example). bootstrap.sh sources them into a dedicated travel-tools-secrets
# Secret used only by the MCP server.
